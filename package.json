{
  "name": "dealiix-platform",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "description": "DealiiX Platform",
  "main": "dist-electron/electron/main.js",
  "author": "Dualistic",
  "build": {
    "appId": "com.dualistic.dealiix-platform",
    "productName": "dealiix-platform",
    "linux": {
      "target": "deb",
      "category": "Utility",
      "maintainer": "Dualistic",
      "description": "DealiiX Platform"
    }
  },
  "scripts": {
    "dev:vite": "vite",
    "dev": "npm run build:electron && npm run build:dev && electron --no-sandbox .",
    "build:dev": "vite build --config vite.config.dev.js",
    "build": "npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.electron.preload.json",
    "preview": "vite preview",
    "start": "electron --no-sandbox .",
    "start:debug": "electron . --inspect=9229",
    "start:forge": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:deb": "electron-forge make --targets=@electron-forge/maker-deb",
    "make:dmg": "electron-forge make --targets=@electron-forge/maker-zip,@electron-forge/maker-dmg",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:electron": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.electron.preload.json --noEmit",
    "format": "prettier . --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@xyflow/svelte": "^1.5.1",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.28.1",
    "svelte-check": "^4.4.5",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.3.5",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "ansi_up": "^6.0.6",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "fs": "^0.0.1-security",
    "ssh2": "^1.16.0"
  }
}
