{
  "name": "dealiix-platform",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "description": "DealiiX Platform",
  "main": "electron/main.js",
  "author": "Dualistic",
  "build": {
    "appId": "com.example.app",
    "productName": "MyApp",
    "linux": {
      "target": "deb",
      "category": "Utility",
      "maintainer": "xxx",
      "description": "DealiiX Platform"
    }
  },
  "scripts": {
    "dev:vite": "vite",
    "dev": "npm run build && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "start:debug": "electron . --inspect=9229",
    "start:forge": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:deb": "electron-forge make --targets=@electron-forge/maker-deb",
    "make:dmg": "electron-forge make --targets=@electron-forge/maker-zip,@electron-forge/maker-dmg",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@xyflow/svelte": "^1.1.0",
    "cross-env": "^7.0.3",
    "electron": "^37.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.28.1",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "fs": "^0.0.1-security",
    "ssh2": "^1.16.0"
  }
}
